#include <Wire.h>

#include <LiquidCrystal_I2C.h>

#include <Keypad.h>


LiquidCrystal_I2C lcd(0x27, 16, 2);


const byte ROWS = 4; 

const byte COLS = 4; 


char hexaKeys[ROWS][COLS] = {

  {'1','2','3','A'},

  {'4','5','6','B'},

  {'7','8','9','C'},

  {'*','0','#','D'}

};


byte rowPins[ROWS] = {2, 3, 6, 7}; 

byte colPins[COLS] = {8, 9, 10, 12}; 


Keypad customKeypad = Keypad(makeKeymap(hexaKeys), rowPins, colPins, ROWS, COLS); 


const int greenLed = 4;   

const int redLed = 5;     

const int buzzerPin = 11; 


const String correctPassword = "1234";

String inputPassword = "";


void setup() {

  pinMode(greenLed, OUTPUT);

  pinMode(redLed, OUTPUT);

  pinMode(buzzerPin, OUTPUT);

  

  Wire.begin();

  lcd.init();

  lcd.backlight();

  

  showIdleScreen();

}


void loop() {

  char customKey = customKeypad.getKey();

  

  if (customKey) {

    tone(buzzerPin, 1000, 80); // Quick beep


    if (customKey == 'A') {

      if (inputPassword == correctPassword) {

        unlockSystem();

      } else {

        wrongPassword();

      }

      inputPassword = ""; 

      showIdleScreen();

    } 

    else if (customKey == 'C') {

      inputPassword = "";

      lcd.setCursor(6, 1);

      lcd.print("    "); 

    } 

    else if (customKey != 'B' && customKey != 'D' && customKey != '*' && customKey != '#') {

      if (inputPassword.length() < 4) {

        lcd.setCursor(6 + inputPassword.length(), 1);

        inputPassword += customKey;

        lcd.print("*"); 

      }

    }

  }

}


void showIdleScreen() {

  digitalWrite(redLed, HIGH);

  digitalWrite(greenLed, LOW);


  lcd.clear();

  lcd.setCursor(0, 0);

  lcd.print("SYSTEM LOCKED");

  lcd.setCursor(0, 1);

  lcd.print("Code: ");

}


void unlockSystem() {

  digitalWrite(redLed, LOW);

  digitalWrite(greenLed, HIGH);


  lcd.clear();

  lcd.setCursor(0, 0);

  lcd.print("ACCESS GRANTED!");

  lcd.setCursor(0, 1);

  lcd.print("Welcome home :)");

  

  tone(buzzerPin, 1200, 150);

  delay(200);

  tone(buzzerPin, 1800, 400);

  

  delay(4000); 

}


void wrongPassword() {

  lcd.clear();

  lcd.setCursor(0, 0);

  lcd.print("ACCESS DENIED!");

  lcd.setCursor(0, 1);

  lcd.print("Wrong Code!");

  

  for(int i=0; i<3; i++) {

    digitalWrite(redLed, LOW);

    delay(150);

    digitalWrite(redLed, HIGH);

    tone(buzzerPin, 300, 150);

    delay(150);

  }

  

  delay(1000);

}
